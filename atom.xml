    <title>2024LLMs与数据科学讲座</title>
    <link href="http://weyumm.github.io/2024/10/15/2024LLMs%E4%B8%8E%E6%95%B0%E6%8D%AE%E7%A7%91%E5%AD%A6%E8%AE%B2%E5%BA%A7/"/>
    <id>http://weyumm.github.io/2024/10/15/2024LLMs%E4%B8%8E%E6%95%B0%E6%8D%AE%E7%A7%91%E5%AD%A6%E8%AE%B2%E5%BA%A7/</id>
    <published>2024-10-15T09:25:17.000Z</published>
